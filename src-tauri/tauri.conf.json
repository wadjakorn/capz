{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "capz",
  "version": "0.9.2",
  "identifier": "dev.baze.capz",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$TEMP/**",
          "**/capz-temp-*.jpg",
          "**/capz-temp-*.png"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/tray/*.png"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://wadjakorn.github.io/capz/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwM0JCRDk1MDhGQTRCOEUKUldTT1Mvb0lsYjA3a09qN3M4R21JZnFsTExtMlozcDIyY2N3Y1VMZnB3d1h4ZHV6UjNBSTlTb3cK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
