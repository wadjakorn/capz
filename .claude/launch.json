{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js dev (browser only)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Tauri dev (desktop app + Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["tauri", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Ladle (design system)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["ladle"],
      "port": 61000,
      "autoPort": false
    }
  ]
}
